[Unit]
Description=Road User Platform Backend API
After=network-online.target mosquitto.service
Wants=network-online.target

[Service]
Type=simple
User=roaduser
WorkingDirectory=/opt/road-user-platform
EnvironmentFile=/etc/road-user-platform/server-common.env
ExecStart=/opt/road-user-platform/.venv/bin/uvicorn src.backend_api.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

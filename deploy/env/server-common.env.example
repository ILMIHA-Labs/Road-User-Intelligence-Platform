PYTHONPATH=/opt/road-user-platform/src
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_API_URL=http://127.0.0.1:8000
CAMERA_CONFIG_PATH=/opt/road-user-platform/config/cameras.yaml
DEFAULT_PIXELS_PER_METER=25.0
DEFAULT_SPEED_LIMIT_KMH=60.0
DEFAULT_SPEED_TOLERANCE_KMH=0.0
SEVERE_SPEED_DELTA_KMH=20.0
SPEED_RESET_DELTA_KMH=5.0
STOPPED_SPEED_THRESHOLD_KMH=3.0
STOPPED_DURATION_SECONDS=20
STOPPED_RESUME_SPEED_KMH=8.0
MAX_MOTORCYCLE_RIDERS=2
RIDER_ASSOCIATION_WINDOW_SECONDS=2
RIDER_HORIZONTAL_MARGIN_RATIO=0.35
RIDER_UPPER_MARGIN_RATIO=0.75
RIDER_LOWER_MARGIN_RATIO=0.25
VIOLATION_STATE_TTL_SECONDS=120
DATABASE_URL=sqlite:////opt/road-user-platform/road_user_platform.db
EVIDENCE_CAPTURE_ENABLED=false
VIOLATION_EVIDENCE_RETENTION_SECONDS=604800
LIVE_PREVIEW_RETENTION_SECONDS=86400
SETUP_PREVIEW_RETENTION_SECONDS=86400
LIVE_CLIP_RETENTION_SECONDS=86400
VIDEO_ANALYSIS_RETENTION_SECONDS=86400
VIDEO_ANALYSIS_MAX_UPLOAD_MB=500
VIDEO_ANALYSIS_MAX_CONCURRENT_JOBS=1

# Privacy redaction
# Imagery redaction (face/plate blur on stored evidence + analysis video) is
# ON by default; it only affects imagery that is actually stored.
REDACTION_ENABLED=true
REDACT_FACES=true
REDACT_PLATES=true
REDACTION_METHOD=blur          # blur | pixelate
REDACTION_STRENGTH=25
# k-anonymity on aggregate research endpoints; 0 disables, >=2 suppresses any
# positive group count below the threshold.
REDACTION_MIN_GROUP=0

# Alerting & camera-health monitoring (disabled by default)
ALERTS_ENABLED=false
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
# Comma-separated violation types to alert on; empty = all supported types
ALERT_VIOLATION_TYPES=
ALERT_DEBOUNCE_SECONDS=60
ALERT_MQTT_ENABLED=false
ALERT_MQTT_TOPIC=alerts/events
CAMERA_OFFLINE_AFTER_SECONDS=60
CAMERA_HEALTH_POLL_SECONDS=30
ALERT_CAMERA_RECOVERY_ENABLED=true
